@{
    var profile = await ProfileService.GetCurrentAsync();
    var currentUser = await UserManager.GetUserAsync(User);
}

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                <div class="user-avatar">
                    @if (!string.IsNullOrEmpty(currentUser?.FullName))
                    {
                        <span>@(currentUser.FullName[0])</span>
                    }
                    else
                    {
                        <i class="bi bi-person-circle"></i>
                    }
                </div>
                <span>@(currentUser?.FullName ?? User.Identity?.Name)</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end biz-dropdown">
                <li>
                    <a class="dropdown-item" asp-controller="BusinessProfile" asp-action="Index">
                        <i class="bi bi-person"></i> @ViewsSharedLocalizer["Profile"]
                    </a>
                </li>
                @if (User.IsInRole(Constants.AdminRole))
                {
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" asp-controller="BusinessProfile" asp-action="Edit">
                            <i class="bi bi-palette"></i> @ViewsSharedLocalizer["CustomizeSystem"]
                        </a>
                    </li>
                }
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-action="Logout" asp-controller="Account" method="post" id="logoutForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="bi bi-box-arrow-right"></i> @ViewsSharedLocalizer["Logout"]
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-action="Register" asp-controller="Account">
                <i class="bi bi-person-plus"></i> @ViewsSharedLocalizer["Register"]
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link btn btn-outline-light btn-sm ms-2 px-3" asp-action="Login" asp-controller="Account">
                <i class="bi bi-box-arrow-in-right"></i> @ViewsSharedLocalizer["Login"]
            </a>
        </li>
    }
</ul>