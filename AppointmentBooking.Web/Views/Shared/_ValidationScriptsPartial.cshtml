<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

<script>
    // Customize jQuery Validation messages to Arabic
    $.validator.messages.required = '@Html.Raw(@ViewsSharedLocalizer["Validation_Required"])';
    $.validator.messages.email = '@Html.Raw(@ViewsSharedLocalizer["Validation_Email"])';
    $.validator.messages.minlength = $.validator.format('@Html.Raw(@ViewsSharedLocalizer["Validation_MinLength"])');
    $.validator.messages.maxlength = $.validator.format('@Html.Raw(@ViewsSharedLocalizer["Validation_MaxLength"])');
    $.validator.messages.equalTo = '@Html.Raw(@ViewsSharedLocalizer["Validation_EqualTo"])';
    $.validator.messages.remote = '@Html.Raw(@ViewsSharedLocalizer["Validation_Remote"])';
    
    // Override unobtrusive validation to work with our custom styling
    $(document).ready(function() {
        $('form').each(function() {
            var $form = $(this);
            var validator = $form.data('validator');
            
            if (validator) {
                validator.settings.highlight = function(element, errorClass, validClass) {
                    $(element).addClass('is-invalid').removeClass('is-valid');
                };
                validator.settings.unhighlight = function(element, errorClass, validClass) {
                    $(element).removeClass('is-invalid').addClass('is-valid');
                };
            }
        });
    });
</script>