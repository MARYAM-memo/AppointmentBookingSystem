@model BusinessProfileViewModel

<style id="theme-shared-variables">
    /* ============================================
       DYNAMIC THEME VARIABLES - AppointmentBooking
       ============================================ */

    :root {
        /* Brand Colors */
        --biz-primary:
            @Model.Colors.Primary
        ;
        --biz-secondary:
            @Model.Colors.Secondary
        ;
        --biz-accent:
            @Model.Colors.Accent
        ;
        --biz-primary-hover:
            @DarkenColor(Model.Colors.Primary,
            10);
        --biz-secondary-hover:
            @DarkenColor(Model.Colors.Secondary,
            10);
        --biz-accent-hover:
            @DarkenColor(Model.Colors.Accent,
            10);

        /* RGB versions for opacity */
        --biz-primary-rgb:
            @Methods.HexToRgb(Model.Colors.Primary)
        ;
        --biz-secondary-rgb:
            @Methods.HexToRgb(Model.Colors.Secondary)
        ;
        --biz-accent-rgb:
            @Methods.HexToRgb(Model.Colors.Accent)
        ;

        /* Dark Mode Colors */
        --biz-dark-primary:
            @(Model.Colors.DarkModePrimary
            ??
            Model.Colors.Primary)
        ;

        /* Typography */
        --biz-font-family:
            @Methods.GetFontFamily(Model.Lang)
        ;
        --biz-font-size-base: 1rem;
        --biz-line-height: 1.6;

        /* Direction */
        --biz-dir:
            @Model.Dir
        ;
        --biz-start:
            @(Model.IsRtl
            ?
"right" :
"left")
        ;
        --biz-end:
            @(Model.IsRtl
            ?
"left" :
        "right")
        ;

        /* Spacing */
        --biz-spacing-xs: 0.25rem;
        --biz-spacing-sm: 0.5rem;
        --biz-spacing-md: 1rem;
        --biz-spacing-lg: 1.5rem;
        --biz-spacing-xl: 3rem;

        /* Border Radius */
        --biz-radius-sm: 0.375rem;
        --biz-radius-md: 0.5rem;
        --biz-radius-lg: 0.75rem;
        --biz-radius-xl: 1rem;

        /* Shadows */
        --biz-shadow-sm: 0 1px 2px rgba(var(--biz-primary-rgb), 0.05);
        --biz-shadow-md: 0 4px 6px rgba(var(--biz-primary-rgb), 0.07);
        --biz-shadow-lg: 0 10px 15px rgba(var(--biz-primary-rgb), 0.1);
        --biz-shadow-primary: 0 4px 14px rgba(var(--biz-primary-rgb), 0.25);

        /* Transitions */
        --biz-transition-fast: 150ms ease;
        --biz-transition-base: 250ms ease;
        --biz-transition-slow: 350ms ease;
    }

    /* Dark Mode Variables */
    [data-bs-theme="dark"] {
        --biz-primary: var(--biz-dark-primary);
        --biz-primary-rgb:
            @Methods.HexToRgb(Model.Colors.DarkModePrimary
            ??
            Model.Colors.Primary)
        ;
    }
</style>

@functions {
    private string DarkenColor(string hex, int percent)
    {
        if (string.IsNullOrEmpty(hex) || hex.Length < 7) return hex;
        try
        {
            var r = Math.Max(0, Convert.ToInt32(hex.Substring(1, 2), 16) - percent * 255 / 100);
            var g = Math.Max(0, Convert.ToInt32(hex.Substring(3, 2), 16) - percent * 255 / 100);
            var b = Math.Max(0, Convert.ToInt32(hex.Substring(5, 2), 16) - percent * 255 / 100);
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch { return hex; }
    }
}