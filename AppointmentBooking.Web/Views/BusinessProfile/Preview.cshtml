@using AppointmentBooking.Web.Resources.Views.BusinessProfile
@inject IStringLocalizer<BusinessProfileResource> Localizer

@model BusinessProfileViewModel
@{
    ViewData["Title"] = Localizer["PageTitle_Preview"];
    Layout = null;
}

<!DOCTYPE html>
<html lang="@Model.Lang" dir="@Model.Dir">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Localizer["Preview_Title"] @Model.BusinessName</title>

    @if (Model.Localization.Direction == "rtl")
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    }

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

    <style>
            .preview-navbar {
                background: linear-gradient(135deg, var(--biz-primary), var(--biz-secondary));
                padding: 1rem 2rem;
                color: white;
            }

            .preview-hero {
                background: linear-gradient(135deg, rgba(var(--biz-primary-rgb), 0.05), rgba(var(--biz-secondary-rgb), 0.05));
                padding: 4rem 2rem;
                text-align: center;
            }

            .preview-btn-primary {
                background: linear-gradient(135deg, var(--biz-primary), var(--biz-secondary));
                color: white;
                border: none;
                padding: 0.75rem 2rem;
                border-radius: 0.5rem;
                font-weight: 600;
            }

            .preview-btn-accent {
                background: var(--biz-accent);
                color: white;
                border: none;
                padding: 0.75rem 2rem;
                border-radius: 0.5rem;
                font-weight: 600;
            }

            .preview-card {
                border: 1px solid rgba(var(--biz-primary-rgb), 0.1);
                border-radius: 1rem;
                padding: 1.5rem;
                transition: all 0.2s;
            }

            .preview-card:hover {
                box-shadow: 0 10px 30px rgba(var(--biz-primary-rgb), 0.1);
            }

            .preview-icon {
                width: 50px;
                height: 50px;
                background: rgba(var(--biz-primary-rgb), 0.1);
                color: var(--biz-primary);
                border-radius: 0.75rem;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
                margin-bottom: 1rem;
            }
    </style>
</head>

<body>
    <!-- Navbar -->
    <nav class="preview-navbar">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl" alt="" style="height: 40px;" />
                }
                else
                {
                    <i class="bi bi-calendar-check-fill fs-4"></i>
                }
                <span class="fw-bold fs-5">@Model.BusinessName</span>
            </div>
            <div>
                <button class="btn btn-outline-light btn-sm">@Model.CustomLabels.GetValueOrDefault("appointment",
                                                                                                                        Localizer["Button_Appointments"].Value)</button>
                </div>
            </div>
        </nav>

        <!-- Hero -->
        <section class="preview-hero">
            <div class="container">
                <h1 class="display-4 fw-bold mb-3" style="color: var(--biz-primary);">@Model.BusinessName</h1>
                @if (!string.IsNullOrEmpty(Model.Tagline))
                {
                    <p class="lead text-muted mb-4">@Model.Tagline</p>
                }
                <button class="preview-btn-primary me-2">@Localizer["Button_BookNow"]</button>
                <button class="preview-btn-accent">@Localizer["Button_AboutUs"]</button>
            </div>
        </section>

        <!-- Services Preview -->
        <section class="py-5">
            <div class="container">
                <h3 class="text-center mb-4 fw-bold" style="color: var(--biz-primary);">
                    @Model.CustomLabels.GetValueOrDefault("service", Localizer["Section_Services"].Value)
                </h3>
                <div class="row g-4">
                    @for (int i = 1; i <= 3; i++)
                    {
                        <div class="col-md-4">
                            <div class="preview-card">
                                <div class="preview-icon">
                                    <i class="bi bi-stars"></i>
                                </div>
                                <h5>@(Model.CustomLabels.GetValueOrDefault("serviceItem", Localizer["Service_Item"].Value)) @i
                                </h5>
                                <p class="text-muted small">@Localizer["Service_Description"]</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold" style="color: var(--biz-primary);">100
                                        @Model.Localization.Currency</span>
                                        <button class="btn btn-sm preview-btn-primary">@Localizer["Button_Book"]</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </section>

            <!-- Footer -->
            <footer class="py-4 text-center text-muted border-top">
                <div class="container">
                    <p class="mb-1">@Model.BusinessName © @DateTime.UtcNow.Year</p>
                    @if (!string.IsNullOrEmpty(Model.Contact.Phone))
                    {
                        <p class="small mb-0"><i class="bi bi-telephone"></i> @Model.Contact.Phone</p>
                    }
                </div>
            </footer>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        </body>

    </html>