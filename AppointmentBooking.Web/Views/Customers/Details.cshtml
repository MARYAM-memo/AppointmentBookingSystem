@using AppointmentBooking.Application.ViewModels.Customer
@using AppointmentBooking.Web.Resources.Views.Customers
@inject IStringLocalizer<CustomerResource> Localizer

@model CustomerResponseViewModel
@{
    ViewData["Title"] = Model.Customer.FullName;
    var labels = ViewBag.CustomLabels as Dictionary<string, string> ?? new Dictionary<string, string>();
    var customer = Model.Customer;
}

@* Header *@
<div class="d-flex align-items-center gap-3 m-4">
    <a asp-action="Index" class="btn btn-icon btn-ghost">
        <i class="bi bi-arrow-right"></i>
    </a>
    <div class="flex-grow-1">
        <h2 class="fw-bold mb-0">@customer.FullName</h2>
        <p class="text-muted mb-0">@Localizer["PageTitle_CustomerCard"]</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-primary">
            <i class="bi bi-pencil"></i> @ViewsSharedLocalizer["Button_Edit"]
        </a>
        <form asp-action="Delete" asp-route-id="@customer.Id" method="post" class="d-inline"
              onsubmit="return confirm('@Localizer["Delete_ConfirmMessage"] @customer.FullName؟');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-trash"></i> @ViewsSharedLocalizer["Button_Delete"]
            </button>
        </form>
    </div>
</div>

<div class="row g-4 m-4">
    @* Profile Card *@
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 text-center">
            <div class="card-body p-4">
                <div class="customer-detail-avatar mx-auto mb-3" style="width: 120px; height: 120px; border-radius: 50%;
                    background: linear-gradient(135deg, var(--biz-primary), var(--biz-secondary));
                    color: white; display: flex; align-items: center; justify-content: center;
                    font-size: 3rem; font-weight: 700; box-shadow: var(--shadow-lg);">
                    @customer.FullName[0]
                </div>
                <h4 class="fw-bold mb-1">@customer.FullName</h4>
                <p class="text-muted mb-3">@Localizer["Customer_Since"] @customer.JoinDate</p>

                <div class="d-flex justify-content-center gap-2 mb-3">
                    <a href="tel:@customer.PhoneNumber" class="btn btn-success btn-sm">
                        <i class="bi bi-telephone-fill"></i> @Localizer["Button_Call"]
                    </a>
                    @if (!string.IsNullOrEmpty(customer.Email))
                    {
                        <a href="mailto:@customer.Email" class="btn btn-primary btn-sm">
                            <i class="bi bi-envelope-fill"></i> @Localizer["Button_Email"]
                        </a>
                    }
                </div>

                <hr />

                <div class="row g-2 text-center">
                    <div class="col-6">
                        <h5 class="fw-bold text-primary mb-0">@customer.TotalAppointments</h5>
                        <small class="text-muted">@Localizer["Label_Booking"]</small>
                    </div>
                    <div class="col-6">
                        <h5 class="fw-bold text-success mb-0">@Model.TotalSpent.ToString("N0")</h5>
                        <small class="text-muted">@Localizer["Label_TotalSpent"]</small>
                    </div>
                </div>
            </div>
        </div>

        @* Contact Info *@
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-person-lines-fill text-primary me-2"></i>
                    @Localizer["ContactInfo_Title"]
                </h6>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="d-flex align-items-center gap-3 py-2 border-bottom">
                        <div class="icon-box bg-success bg-opacity-10 text-success">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">@Localizer["Label_PhoneNumber"]</small>
                            <span class="fw-bold" dir="ltr">@customer.PhoneNumber</span>
                        </div>
                    </li>
                    @if (!string.IsNullOrEmpty(customer.Email))
                    {
                        <li class="d-flex align-items-center gap-3 py-2 border-bottom">
                            <div class="icon-box bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-envelope-fill"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">@Localizer["Label_Email"]</small>
                                <span class="fw-bold">@customer.Email</span>
                            </div>
                        </li>
                    }
                    <li class="d-flex align-items-center gap-3 py-2 border-bottom">
                        <div class="icon-box bg-info bg-opacity-10 text-info">
                            <i class="bi bi-calendar-fill"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">@Localizer["Label_AddedDate"]</small>
                            <span class="fw-bold">@customer.CreatedAt.ToString("yyyy/MM/dd")</span>
                        </div>
                    </li>
                    @if (customer.LastAppointmentDate.HasValue)
                    {
                        <li class="d-flex align-items-center gap-3 py-2">
                            <div class="icon-box bg-warning bg-opacity-10 text-warning">
                                <i class="bi bi-clock-history"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">@Localizer["Label_LastVisit"]</small>
                                <span class="fw-bold">@customer.LastAppointmentDate.Value.ToString("yyyy/MM/dd")</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>

        @* Notes *@
        @if (!string.IsNullOrEmpty(customer.Notes))
        {
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header py-3">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-stickies text-warning me-2"></i>
                        @ViewsSharedLocalizer["Label_Notes"]
                    </h6>
                </div>
                <div class="card-body">
                    <p class="mb-0 text-muted">@customer.Notes</p>
                </div>
            </div>
        }
    </div>

    @* Appointments History *@
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-calendar-week text-primary me-2"></i>
                    @Localizer["AppointmentsHistory_Title"]
                </h5>
                <a asp-controller="Appointments" asp-action="Create" asp-route-customerId="@customer.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-lg"></i> @ViewsSharedLocalizer["Button_NewBooking"]
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.Appointments.Any())
                {
                    <div class="table-responsive">
                        <table class="app-table mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer["TableHeader_ID"]</th>
                                    <th>@labels.GetLabel("serviceItem", ViewsSharedLocalizer["TableHeader_Service"])
                                    </th>
                                    <th>@ViewsSharedLocalizer["TableHeader_Date"]</th>
                                    <th>@ViewsSharedLocalizer["TableHeader_Time"]</th>
                                    <th>@ViewsSharedLocalizer["TableHeader_Status"]</th>
                                    <th>@ViewsSharedLocalizer["TableHeader_Price"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var apt in Model.Appointments)
                                {
                                    <tr>
                                        <td class="fw-bold text-muted">#@apt.Id</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(apt.Service?.Color))
                                                {
                                                    <span class="d-inline-block rounded-circle"
                                                          style="width: 10px; height: 10px; background: @apt.Service.Color;"></span>
                                                }
                                                <span>@apt.Service?.Name</span>
                                            </div>
                                        </td>
                                        <td>@apt.AppointmentDate.ToString("yyyy/MM/dd")</td>
                                        <td dir="ltr" class="text-center">@apt.StartTime.FormatTime()</td>
                                        <td>
                                            @{
                                                var statusClass = apt.Status.GetCssClass();
                                                var statusText = apt.Status.GetLocalizedName();
                                            }
                                            <span class="badge bg-@statusClass bg-opacity-10 text-@statusClass">
                                                @statusText
                                            </span>
                                        </td>
                                        <td class="fw-bold">
                                            @(apt.FinalPrice?.ToCurrency() ?? apt.TotalPrice?.ToCurrency() ?? "-")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x display-4 text-muted"></i>
                        <h6 class="text-muted mt-2">@Localizer["EmptyState_NoAppointments"]</h6>
                        <a asp-controller="Appointments" asp-action="Create" asp-route-customerId="@customer.Id"
                           class="btn btn-primary btn-sm mt-2">
                            <i class="bi bi-plus-lg"></i> @Localizer["Button_CreateFirstBooking"]
                        </a>
                    </div>
                }
            </div>
        </div>

        @* Quick Stats Chart *@
        @if (Model.Appointments.Any())
        {
            <div class="row g-3 mt-2">
                @{
                    var completed = Model.Appointments.Count(a => a.Status == BookingStatus.Completed);
                    var cancelled = Model.Appointments.Count(a => a.Status == BookingStatus.Cancelled || a.Status ==
            BookingStatus.NoShow);
                    var pending = Model.Appointments.Count(a => a.Status == BookingStatus.Pending || a.Status ==
            BookingStatus.Confirmed);
                }
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm bg-success bg-opacity-10">
                        <div class="card-body text-center">
                            <h4 class="fw-bold text-success mb-0">@completed</h4>
                            <small class="text-success">@Localizer["Stats_Completed"]</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm bg-primary bg-opacity-10">
                        <div class="card-body text-center">
                            <h4 class="fw-bold text-primary mb-0">@pending</h4>
                            <small class="text-primary">@Localizer["Stats_Upcoming"]</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm bg-danger bg-opacity-10">
                        <div class="card-body text-center">
                            <h4 class="fw-bold text-danger mb-0">@cancelled</h4>
                            <small class="text-danger">@Localizer["Stats_Cancelled"]</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .icon-box {
            width: 40px;
            height: 40px;
            border-radius: var(--border-radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .customer-detail-avatar {
            transition: transform var(--transition-base);
        }

        .customer-detail-avatar:hover {
            transform: scale(1.05);
        }
    </style>
}