@using AppointmentBooking.Web.Resources.Views.Errors
@inject IStringLocalizer<ErrorsResource> Localizer

@model ErrorPageViewModel
@{
    Layout = "~/Views/Errors/_ErrorMaster.cshtml";
}

<div class="error-icon-wrap error-icon-500">
    <i class="bi @Model.Icon"></i>
</div>

<div class="error-code error-code-500">@Model.StatusCode</div>
<h1 class="error-title">@Model.Title</h1>
<p class="error-message">@Model.Message</p>
<p class="error-description">@Model.Description</p>

<div class="mb-4">
    <div class="alert alert-danger d-inline-flex align-items-center gap-2">
        <i class="bi bi-robot fs-4"></i>
        <div>
            <strong>@Localizer["Error_SupportNotified"]</strong> @Localizer["Error_WorkingOnFix"]
        </div>
    </div>
</div>

@if (Model.ShowDetails && !string.IsNullOrEmpty(Model.ExceptionDetails))
{
    <div class="error-trace mb-3">
        <div class="error-trace-label">@Localizer["Error_TechnicalDetailsDev"]</div>
        <div class="error-trace-exception">@Model.ExceptionDetails</div>
    </div>
}

<div class="error-suggestions">
    @foreach (var suggestion in Model.Suggestions)
    {
        <a href="@suggestion.Url"
           class="error-suggestion-btn @(suggestion == Model.Suggestions.First() ? "error-suggestion-primary" : "error-suggestion-outline")">
            <i class="bi @suggestion.Icon"></i>
            @suggestion.Text
        </a>
    }
</div>

<div class="error-trace">
    <div class="error-trace-label">@Localizer["Error_TrackingIdLabel"]</div>
    <div class="error-trace-value" id="traceId">@Model.TraceId</div>
    <button class="btn btn-sm btn-outline-secondary mt-2" onclick="copyTraceId()">
        <i class="bi bi-clipboard"></i> @Localizer["Button_Copy"]
    </button>
</div>

@section Scripts {
    <script>
        function copyTraceId() {
            const traceId = document.getElementById('traceId').textContent;
            navigator.clipboard.writeText(traceId).then(() => {
                BizToast.success('@Localizer["Toast_Copied"]');
            });
        }
    </script>
}