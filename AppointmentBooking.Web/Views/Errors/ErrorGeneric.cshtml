@using AppointmentBooking.Web.Resources.Views.Errors
@inject IStringLocalizer<ErrorsResource> Localizer

@model ErrorPageViewModel
@{
    Layout = "~/Views/Errors/_ErrorMaster.cshtml";
}

<div class="error-icon-wrap" style="background: #f3f4f6; color: #6b7280;">
    <i class="bi @Model.Icon"></i>
</div>

<div class="error-code" style="color: #6b7280;">@Model.StatusCode</div>
<h1 class="error-title">@Model.Title</h1>
<p class="error-message">@Model.Message</p>
<p class="error-description">@Model.Description</p>

@if (Model.ShowDetails && !string.IsNullOrEmpty(Model.ExceptionDetails))
{
    <div class="error-trace">
        <div class="error-trace-label">@Localizer["Error_TechnicalDetails"]</div>
        <div class="error-trace-exception">@Model.ExceptionDetails</div>
    </div>
}

<div class="error-suggestions">
    @foreach (var suggestion in Model.Suggestions)
    {
        <a href="@suggestion.Url"
           class="error-suggestion-btn @(suggestion == Model.Suggestions.First() ? "error-suggestion-primary" : "error-suggestion-outline")">
            <i class="bi @suggestion.Icon"></i>
            @suggestion.Text
        </a>
    }
</div>

<div class="error-trace">
    <div class="error-trace-label">@Localizer["Error_TrackingId"]</div>
    <div class="error-trace-value">@Model.TraceId</div>
</div>