@using AppointmentBooking.Application.ViewModels.Appointment
@using AppointmentBooking.Web.Resources.Views.Appointments

@inject IStringLocalizer<AppointmentResource> Localizer

@model AppointmentRequestViewModel
@{
      var isEdit = ViewBag.IsEdit as bool? ?? false;
      var labels = ViewBag.CustomLabels as Dictionary<string, string> ?? new Dictionary<string, string>();
      ViewData["Title"] = (isEdit ? ViewsSharedLocalizer["Button_Edit"] : Localizer["Booking_Add"]) + " " +
Localizer["Booking_Title"];

}

@* Page Header *@
<div class="d-flex align-items-center gap-3 m-4">
      <a asp-action="Index" class="btn btn-icon btn-ghost">
            <i class="bi bi-arrow-right"></i>
      </a>
      <div>
            <h2 class="fw-bold mb-0">@ViewData["Title"]</h2>
            <p class="text-muted mb-0">@(isEdit ? Localizer["Booking_UpdateData"] : Localizer["Booking_CreateNew"])</p>
      </div>
</div>

<div class="row g-4 m-4">
      @* Main Form *@
      <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                  <div class="card-body p-4">
                        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" id="appointmentForm" novalidate>
                              @Html.AntiForgeryToken()
                              @if (isEdit)
                              {
                                    <input type="hidden" asp-for="Id" />
                              }

                              <div class="row g-3">
                                    @* Customer *@
                                    <div class="col-md-6">
                                          <label asp-for="CustomerId"
                                                 class="form-label fw-bold">@ViewsSharedLocalizer["TableHeader_Customer"]</label>
                                          <div class="input-group">
                                                <span class="input-group-text bg-light">
                                                      <i class="bi bi-person text-muted"></i>
                                                </span>
                                                <select asp-for="CustomerId" class="form-select"
                                                        asp-items="ViewBag.Customers" required>
                                                      <option value="">@Localizer["Placeholder_SelectCustomer"]</option>
                                                </select>
                                          </div>
                                          <span asp-validation-for="CustomerId" class="text-danger small"></span>
                                          <div class="form-text">
                                                <a asp-controller="Customers" asp-action="Create" target="_blank">
                                                      <i class="bi bi-plus-circle"></i> @Localizer["Link_NewCustomer"]
                                                </a>
                                          </div>
                                    </div>

                                    @* Service *@
                                    <div class="col-md-6">
                                          <label asp-for="ServiceId"
                                                 class="form-label fw-bold">@Localizer["Label_SelectService"]</label>
                                          <div class="input-group">
                                                <span class="input-group-text bg-light">
                                                      <i class="bi bi-stars text-muted"></i>
                                                </span>
                                                <select asp-for="ServiceId" class="form-select"
                                                        asp-items="ViewBag.Services" id="ServiceId" required
                                                        onchange="onServiceChange()">
                                                      <option value="">@Localizer["Placeholder_SelectService"]</option>
                                                </select>
                                          </div>
                                          <span asp-validation-for="ServiceId" class="text-danger small"></span>
                                    </div>

                                    @* Date *@
                                    <div class="col-md-6">
                                          <label asp-for="AppointmentDate"
                                                 class="form-label fw-bold">@Localizer["Label_AppointmentDate"]</label>
                                          <div class="input-group">
                                                <span class="input-group-text bg-light">
                                                      <i class="bi bi-calendar text-muted"></i>
                                                </span>
                                                <input asp-for="AppointmentDate" type="date" class="form-control"
                                                       id="AppointmentDate" required onchange="onDateChange()"
                                                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                                       max="@DateTime.Today.AddMonths(3).ToString("yyyy-MM-dd")" />
                                          </div>
                                          <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                                    </div>

                                    @* Status *@
                                    <div class="col-md-6">
                                          <label asp-for="Status"
                                                 class="form-label fw-bold">@ViewsSharedLocalizer["TableHeader_Status"]</label>
                                          <div class="input-group">
                                                <span class="input-group-text bg-light">
                                                      <i class="bi bi-flag text-muted"></i>
                                                </span>
                                                <select asp-for="Status" class="form-select"
                                                        asp-items="ViewBag.StatusList"></select>
                                          </div>
                                    </div>

                                    @* Time Slots *@
                                    <div class="col-12">
                                          <label id="timeLabel"
                                                 class="form-label fw-bold">@Localizer["Label_SelectTime"]</label>
                                          <div id="slotsContainer" class="slots-grid" role="group"
                                               aria-labelledby="timeLabel">
                                                <div class="text-center py-4 text-muted" id="slotsPlaceholder">
                                                      <i class="bi bi-clock-history display-4"></i>
                                                      <p class="mt-2">@Localizer["Message_SelectServiceAndDate"]</p>
                                                </div>
                                          </div>
                                          <input type="hidden" asp-for="StartTime" id="startTimeInput" name="StartTime"
                                                 required />
                                          <span asp-validation-for="StartTime" class="text-danger small"></span>
                                    </div>

                                    @* Selected Time Display *@
                                    <div class="col-12" id="selectedTimeDisplay" style="display: none;">
                                          <div class="alert alert-info d-flex align-items-center gap-2">
                                                <i class="bi bi-check-circle-fill"></i>
                                                <span>@Localizer["Message_SelectedTime"] <strong
                                                      id="selectedTimeText"></strong></span>
                                                </div>
                                          </div>

                                          @* Pricing *@
                                          <div class="col-md-4">
                                                <label asp-for="TotalPrice"
                                                       class="form-label fw-bold">@ViewsSharedLocalizer["Label_BasePrice"]</label>
                                                <div class="input-group">
                                                      <input asp-for="TotalPrice" class="form-control readonly-field"
                                                             id="TotalPrice" readonly tabindex="-1" />
                                                      <span class="input-group-text">@PriceExtension.CurrentCurrency</span>
                                                </div>
                                          </div>

                                          <div class="col-md-4">
                                                <label asp-for="DiscountAmount"
                                                       class="form-label fw-bold">@Localizer["Label_Discount"]</label>
                                                <div class="input-group">
                                                      <input asp-for="DiscountAmount" type="number" step="0.01" min="0"
                                                             class="form-control" id="DiscountAmount"
                                                             onchange="calculateFinalPrice()" />
                                                      <span class="input-group-text">@PriceExtension.CurrentCurrency</span>
                                                </div>
                                                <span class="text-danger small" id="discountValidation"></span>
                                                <span asp-validation-for="DiscountAmount" class="text-danger small"
                                                      id="discountValidation"></span>
                                          </div>

                                          <div class="col-md-4">
                                                <label asp-for="FinalPrice"
                                                       class="form-label fw-bold">@Localizer["Label_FinalPrice"]</label>
                                                <div class="input-group">
                                                      <input asp-for="FinalPrice" class="form-control readonly-field"
                                                             id="FinalPrice" readonly tabindex="-1" />
                                                      <span class="input-group-text">@PriceExtension.CurrentCurrency</span>
                                                </div>
                                          </div>

                                          @* Notes *@
                                          <div class="col-12">
                                                <label asp-for="Notes"
                                                       class="form-label fw-bold">@ViewsSharedLocalizer["Label_Notes"]</label>
                                                <textarea asp-for="Notes" class="form-control" rows="3"
                                                          placeholder="@Localizer["Placeholder_Notes"]"></textarea>
                                                <span asp-validation-for="Notes" class="text-danger small"></span>

                                          </div>
                                    </div>

                                    @* Submit *@
                                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                                          <button type="submit" class="btn btn-primary flex-grow-1 fw-bold" id="submitBtn"
                                                  disabled>
                                                <i class="bi bi-check-lg me-1"></i>
                                                @(isEdit ? ViewsSharedLocalizer["Button_SaveChanges"] :
                                                Localizer["Button_CreateBooking"])
                                          </button>
                                          <a asp-action="Index" class="btn btn-outline-secondary">
                                                <i class="bi bi-x-lg"></i> @ViewsSharedLocalizer["Button_Cancel"]
                                          </a>
                                    </div>
                              </form>
                        </div>
                  </div>
            </div>

            @* Side Panel *@
            <div class="col-lg-4">
                  @* Service Preview *@
                  <div class="card shadow-sm border-0" id="servicePreview" style="display: none;">
                        <div class="card-body text-center">
                              <div class="service-preview-icon mb-3" id="previewIconContainer">
                                    <i class="bi bi-stars display-4" id="previewIcon"></i>
                              </div>
                              <h5 class="fw-bold mb-1" id="previewServiceName">@Localizer["ServicePreview_ServiceName"]</h5>
                              <p class="text-muted mb-3" id="previewDuration">30 دقيقة</p>

                              <div class="d-flex justify-content-center gap-3 text-start">
                                    <div>
                                          <small class="text-muted d-block">@ViewsSharedLocalizer["TableHeader_Price"]</small>
                                          <span class="fw-bold fs-5" id="previewPrice">0
                                                @Html.Raw(PriceExtension.CurrentCurrency)</span>
                                          </div>
                                          <div>
                                                <small class="text-muted d-block">@Localizer["Service_TotalDuration"]</small>
                                                <span class="fw-bold" id="previewTotalDuration">30 دقيقة</span>
                                          </div>
                                    </div>
                              </div>
                        </div>

                        @* Quick Info *@
                        <div class="card shadow-sm border-0 mt-4 bg-primary bg-opacity-10">
                              <div class="card-body">
                                    <h6 class="fw-bold text-primary mb-3">
                                          <i class="bi bi-info-circle me-2"></i>
                                          @Localizer["QuickInfo_Title"]
                                    </h6>
                                    <ul class="list-unstyled mb-0 small">
                                          <li class="d-flex align-items-center gap-2 mb-2">
                                                <i class="bi bi-check-circle-fill text-success"></i>
                                                @Localizer["QuickInfo_Step1"]
                                          </li>
                                          <li class="d-flex align-items-center gap-2 mb-2">
                                                <i class="bi bi-check-circle-fill text-success"></i>
                                                @Localizer["QuickInfo_Step2"]
                                          </li>
                                          <li class="d-flex align-items-center gap-2 mb-2">
                                                <i class="bi bi-check-circle-fill text-success"></i>
                                                @Localizer["QuickInfo_Step3"]
                                          </li>
                                          <li class="d-flex align-items-center gap-2">
                                                <i class="bi bi-check-circle-fill text-success"></i>
                                                @Localizer["QuickInfo_Step4"]
                                          </li>
                                    </ul>
                              </div>
                        </div>
                  </div>
            </div>
