@using AppointmentBooking.Application.ViewModels.Appointment
@using AppointmentBooking.Web.Resources.Views.Appointments

@inject IStringLocalizer<AppointmentResource> Localizer
@model AppointmentCalendarViewModel
@{
    ViewData["Title"] = Localizer["Calendar_Title"];
    var labels = ViewBag.CustomLabels as Dictionary<string, string> ?? new Dictionary<string, string>();

    var firstDayOfMonth = new DateTime(Model.CurrentMonth.Year, Model.CurrentMonth.Month, 1);
    var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);
    var startDayOfWeek = (int)firstDayOfMonth.DayOfWeek;
    var daysInMonth = DateTime.DaysInMonth(Model.CurrentMonth.Year, Model.CurrentMonth.Month);

    // Adjust for Sunday start (0) vs Monday start
    var offset = startDayOfWeek == 0 ? 6 : startDayOfWeek - 1;

    var theme = await ProfileService.GetCurrentViewModelAsync();
    var culture = theme.GetCultureInfo();
    var isRTL = theme.IsRtl;

    var currentFilter = ViewBag.CurrentStatusFilter as string;
}

@* Page Header *@
<div class="d-flex flex-wrap justify-content-between align-items-center m-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1">
            <i class="bi bi-calendar3 text-primary me-2"></i>
            @Localizer["Calendar_Title"]
        </h2>
        <p class="text-muted mb-0">@Model.CurrentMonth.ToString("MMMM yyyy", culture)</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-list"></i>
            <span class="d-none d-md-inline">@Localizer["Button_List"]</span>
        </a>
        @if (User.IsInRole(Constants.AdminRole))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i>
                @ViewsSharedLocalizer["Button_NewBooking"]
            </a>
        }
    </div>
</div>

@* Month Navigation *@
<div class="d-flex justify-content-between align-items-center m-4">
    <a asp-action="Calendar" asp-route-startDate="@Model.CurrentMonth.AddMonths(-1).ToString("yyyy-MM-dd")"
       class="btn btn-outline-secondary">
        <i class="bi bi-chevron-@(isRTL? "right":"left")"></i> @Localizer["Button_PreviousMonth"]
    </a>
    <h4 class="fw-bold mb-0">@Model.CurrentMonth.ToString("MMMM yyyy", culture)</h4>
    <a asp-action="Calendar" asp-route-startDate="@Model.CurrentMonth.AddMonths(1).ToString("yyyy-MM-dd")"
       class="btn btn-outline-secondary">
        @Localizer["Button_NextMonth"] <i class="bi bi-chevron-@(isRTL? "left":"right")"></i>
    </a>
</div>

@* Calendar Grid *@
<div class="calendar-wrapper m-4">
    <div class="card border-0 shadow-lg calendar-card">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div class="d-flex align-items-center gap-3">
                    <button type="button" class="btn btn-icon btn-outline-secondary rounded-circle" id="prevMonth">
                        <i class="bi bi-chevron-@(isRTL? "right":"left")"></i>
                    </button>
                    <h3 class="h4 mb-0 fw-bold">
                        <span id="currentMonth">@Model.CurrentMonth.ToString("MMMM yyyy", culture)</span>
                    </h3>
                    <button type="button" class="btn btn-icon btn-outline-secondary rounded-circle" id="nextMonth">
                        <i class="bi bi-chevron-@(isRTL? "left":"right")"></i>
                    </button>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-primary" id="todayBtn">
                        <i class="bi bi-calendar-week me-1"></i>
                        @Localizer["Button_Today"]
                    </button>
                    @* Filter Dropdown - FIXED: Added working filter functionality *@
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-funnel me-1"></i>
                            @Localizer["Button_Filter"]
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 200px;">
                            <div class="mb-2">
                                <label class="form-label small fw-bold">@Localizer["Label_BookingStatus"]</label>
                                <select class="form-select form-select-sm" id="statusFilter">
                                    <option value="" selected="@(string.IsNullOrEmpty(ViewBag.CurrentStatusFilter))">
                                        @Localizer["Status_All"]</option>
                                        <option value="Confirmed" selected="@(ViewBag.CurrentStatusFilter == "Confirmed")">
                                            @Localizer["Status_Confirmed"]</option>
                                            <option value="InProgress"
                                                    selected="@(ViewBag.CurrentStatusFilter == "InProgress")">
                                                @Localizer["Status_InProgress"]</option>
                                                <option value="Completed" selected="@(ViewBag.CurrentStatusFilter == "Completed")">
                                                    @Localizer["Status_Completed"]</option>
                                                    <option value="Cancelled" selected="@(ViewBag.CurrentStatusFilter == "Cancelled")">
                                                        @Localizer["Status_Cancelled"]</option>
                                                    </select>
                                                </div>
                                                <div class="d-flex gap-2 mt-3">
                                                    <button type="button" class="btn btn-sm btn-primary w-100" id="applyFilterBtn">
                                                        <i class="bi bi-check-lg me-1"></i>
                                                        @SharedLocalizer["Action_Confirm"]
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clearFilterBtn"
                                                            title="@SharedLocalizer["Action_Cancel"]">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card-body p-4">
                                @* Weekday Headers *@
                                <div class="calendar-grid calendar-header">
                                    @foreach (var day in new[] { Localizer["Day_Monday"].Value, Localizer["Day_Tuesday"].Value,
                Localizer["Day_Wednesday"].Value, Localizer["Day_Thursday"].Value, Localizer["Day_Friday"].Value,
                Localizer["Day_Saturday"].Value, Localizer["Day_Sunday"].Value })
                                    {
                                        var isWeekendDay = day == Localizer["Day_Friday"].Value || day == Localizer["Day_Saturday"].Value;
                                        <div class="calendar-day-header @(isWeekendDay ? "weekend-header" : "")">
                                            <span>@day</span>
                                        </div>
                                    }
                                </div>

                                @* Days Grid *@
                                <div class="calendar-grid calendar-body" id="calendarDays">
                                    @* Empty cells before start of month *@
                                    @for (var i = 0; i < offset; i++)
                                    {
                                        <div class="calendar-day empty">
                                            <div class="day-number"></div>
                                        </div>
                                    }

                                    @* Days *@
                                    @for (var day = 1; day <= daysInMonth; day++)
                                    {
                                        var date = new DateTime(Model.CurrentMonth.Year, Model.CurrentMonth.Month, day);
                                        var dayAppointments = Model.Appointments.Where(b => b.AppointmentDate.Day == day).ToList();
                                        var isToday = date.Date == DateTime.Today;
                                        var isWeekend = date.DayOfWeek == DayOfWeek.Friday || date.DayOfWeek == DayOfWeek.Saturday;
                                        var hasAppointments = dayAppointments.Any();
                                        var hasFiltered = !string.IsNullOrEmpty(currentFilter) &&
                                               dayAppointments.Any(a => a.Status.ToString() == currentFilter);

                                        <div class="calendar-day @(isToday ? "today" : "") @(isWeekend ? "weekend" : "") @(hasFiltered ? "filter-active" : "")"
                                             data-date="@date.ToString("yyyy-MM-dd")">
                                            <div class="day-header">
                                                <div class="day-number @(isToday ? "today-badge" : "")">
                                                    @day
                                                </div>
                                                @if (hasAppointments)
                                                {
                                                    <span class="appointments-count">@dayAppointments.Count</span>
                                                }
                                            </div>

                                            @if (hasAppointments)
                                            {
                                                <div class="day-appointments">
                                                    @foreach (var appointment in dayAppointments.Take(2))
                                                    {
                                                        var statusColor = appointment.Status.GetCssClass();

                                                        <div class="appointment-badge" data-bs-toggle="tooltip" data-bs-placement="top"
                                                             title="@appointment.Customer?.FullName - @appointment.Service?.Name"
                                                             style="background: @statusColor;">
                                                            <span class="appointment-time">@appointment.StartTime.FormatTime()</span>
                                                        </div>
                                                    }

                                                    @if (dayAppointments.Count > 2)
                                                    {
                                                        @* Removed data-bs-toggle="dropdown" - using custom JS instead *@
                                                        <div class="appointment-badge more-badge" data-dropdown-trigger="true">
                                                            <span>+@(dayAppointments.Count - 2)</span>
                                                        </div>

                                                        @* Dropdown is now positioned relative to the calendar-day, not fixed *@
                                                        <div class="appointments-dropdown" style="display: none;">
                                                            <div class="dropdown-header fw-bold py-2 px-3">
                                                                <i class="bi bi-calendar-event me-2"></i>
                                                                @Localizer["DropdownHeader_TodayAppointments"] @date.ToString("dd/MM")
                                                            </div>
                                                            <div class="dropdown-divider m-0"></div>
                                                            <div class="appointments-list">
                                                                @foreach (var appointment in dayAppointments)
                                                                {
                                                                    var statusClass = appointment.Status.GetCssClass();
                                                                    if (appointment.AppointmentDate > DateTime.Today)
                                                                    {
                                                                        <a asp-action="Edit" asp-route-id="@appointment.Id"
                                                                           class="dropdown-item appointment-item">
                                                                            <div class="d-flex align-items-center gap-2">
                                                                                <div class="status-indicator bg-@statusClass"></div>
                                                                                <div class="flex-grow-1">
                                                                                    <div class="fw-semibold small">@appointment.Customer?.FullName</div>
                                                                                    <div class="text-muted small">@appointment.Service?.Name</div>
                                                                                </div>
                                                                                <div class="appointment-time-small">@appointment.StartTime.FormatTime()</div>
                                                                            </div>
                                                                        </a>
                                                                    }
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    else if (dayAppointments.Count <= 2 && dayAppointments.Count > 0)
                                                    {
                                                        <div class="appointments-tooltip d-none">
                                                            @foreach (var appointment in dayAppointments)
                                                            {
                                                                <div>@appointment.StartTime.FormatTime() - @appointment.Customer?.FullName</div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            @if (User.IsInRole(Constants.AdminRole))
                                            {
                                                <a asp-action="Create" asp-route-date="@date.ToString("yyyy-MM-dd")" class="add-appointment-btn"
                                                   title="@Localizer["Tooltip_AddBooking"]">
                                                    <i class="bi bi-plus-lg"></i>
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="card-footer bg-transparent border-0 pt-0 pb-4 px-4">
                                <div class="legend d-flex flex-wrap gap-4 justify-content-center">
                                    <div class="legend-item">
                                        <div class="legend-color" style="background: #0d6efd;"></div>
                                        <span style="font-size: 1rem;">@Localizer["Legend_Confirmed"]</span>
                                    </div>
                                    <div class="legend-item">
                                        <div class="legend-color" style="background: #6f42c1;"></div>
                                        <span style="font-size: 1rem;">@Localizer["Legend_InProgress"]</span>
                                    </div>
                                    <div class="legend-item">
                                        <div class="legend-color" style="background: #198754;"></div>
                                        <span style="font-size: 1rem;">@Localizer["Legend_Completed"]</span>
                                    </div>
                                    <div class="legend-item">
                                        <div class="legend-color" style="background: #dc3545;"></div>
                                        <span style="font-size: 1rem;">@Localizer["Legend_Cancelled"]</span>
                                    </div>
                                    <div class="legend-item">
                                        <div class="legend-color today-indicator"></div>
                                        <span style="font-size: 1rem;">@Localizer["Legend_Today"]</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>


                    @section Styles {
                        <style>
                            /* Reset and Base */
                            .calendar-wrapper {
                                position: relative;
                                opacity: 1;
                                transform: translateY(0);
                                transition: opacity 0.5s ease, transform 0.5s ease;
                            }

                            .calendar-card {
                                border-radius: 1rem;
                                background: #ffffff;
                                transition: all 250ms ease;
                                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
                            }

                            .calendar-card:hover {
                                box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
                            }

                            /* Dark mode support */
                            [data-bs-theme="dark"] .calendar-card {
                                background: #1a1a2e;
                            }

                            /* Calendar Grid */
                            .calendar-grid {
                                display: grid;
                                grid-template-columns: repeat(7, 1fr);
                                gap: 0.5rem;
                            }

                            /* Header Styles */
                            .calendar-header {
                                margin-bottom: 1rem;
                            }

                            .calendar-day-header {
                                padding: 0.75rem 0.5rem;
                                text-align: center;
                                font-weight: 700;
                                font-size: 0.95rem;
                                color: #6c757d;
                                background: rgba(13, 110, 253, 0.03);
                                border-radius: 0.5rem;
                            }

                            .calendar-day-header.weekend-header {
                                color: #dc3545;
                                background: rgba(220, 53, 69, 0.05);
                            }

                            /* Day Cells - FIXED: Added transform for stacking context */
                            .calendar-body {
                                min-height: 600px;
                            }

                            .calendar-day {
                                min-height: 120px;
                                background: #ffffff;
                                border: 1px solid rgba(13, 110, 253, 0.1);
                                border-radius: 0.75rem;
                                padding: 0.75rem;
                                position: relative;
                                transition: all 150ms ease;
                                cursor: pointer;
                                overflow: visible;
                                /* Create new stacking context but keep dropdown visible */
                                transform: translateZ(0);
                                isolation: isolate;
                            }

                            [data-bs-theme="dark"] .calendar-day {
                                background: rgba(255, 255, 255, 0.05);
                                border-color: rgba(255, 255, 255, 0.1);
                            }

                            .calendar-day:hover {
                                transform: translateY(-2px) translateZ(0);
                                border-color: #0d6efd;
                                box-shadow: 0 4px 12px rgba(13, 110, 253, 0.15);
                                background: rgba(13, 110, 253, 0.02);
                                z-index: 100;
                            }

                            [data-bs-theme="dark"] .calendar-day:hover {
                                background: rgba(13, 110, 253, 0.1);
                            }

                            .calendar-day.empty {
                                background: rgba(13, 110, 253, 0.02);
                                border-color: rgba(13, 110, 253, 0.05);
                                cursor: default;
                            }

                            .calendar-day.empty:hover {
                                transform: translateZ(0);
                                border-color: rgba(13, 110, 253, 0.05);
                                box-shadow: none;
                            }

                            .calendar-day.today {
                                border: 2px solid #0d6efd;
                                background: rgba(13, 110, 253, 0.04);
                            }

                            .calendar-day.weekend:not(.today) {
                                background: rgba(220, 53, 69, 0.02);
                                border-color: rgba(220, 53, 69, 0.15);
                            }

                            /* Day Header */
                            .day-header {
                                display: flex;
                                align-items: center;
                                justify-content: space-between;
                                margin-bottom: 0.75rem;
                            }

                            .day-number {
                                width: 34px;
                                height: 34px;
                                border-radius: 50%;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                font-weight: 700;
                                font-size: 1.3rem;
                                color: #212529;
                                transition: all 150ms ease;
                            }

                            [data-bs-theme="dark"] .day-number {
                                color: #e0e0e0;
                            }

                            .day-number.today-badge {
                                background: #0d6efd;
                                color: white;
                                box-shadow: 0 2px 8px rgba(13, 110, 253, 0.3);
                            }

                            .appointments-count {
                                font-size: 0.8rem;
                                font-weight: 600;
                                color: #0d6efd;
                                background: rgba(13, 110, 253, 0.1);
                                padding: 0.125rem 0.375rem;
                                border-radius: 0.75rem;
                            }

                            /* Booking Badges */
                            .day-appointments {
                                display: flex;
                                flex-direction: column;
                                gap: 0.375rem;
                            }

                            .appointment-badge {
                                padding: 0.25rem 0.5rem;
                                border-radius: 0.375rem;
                                font-size: 0.7rem;
                                font-weight: 600;
                                color: white;
                                cursor: pointer;
                                transition: all 150ms ease;
                                text-align: center;
                                white-space: nowrap;
                                overflow: hidden;
                                text-overflow: ellipsis;
                            }

                            .appointment-badge:hover {
                                transform: scale(1.02);
                                filter: brightness(1.1);
                            }

                            .appointment-badge .appointment-time {
                                font-size: 0.85rem;
                                color: #334155;
                            }

                            [data-bs-theme="dark"] .appointment-badge .appointment-time {

                                color: white;
                            }

                            .more-badge {
                                background: #0d6efd;
                                opacity: 0.8;
                            }

                            /* FIXED: Dropdown Menu - Using absolute positioning with high z-index */
                            .appointments-dropdown {
                                display: none;
                                position: absolute;
                                top: 100%;
                                left: 0;
                                right: 0;
                                background: white;
                                border-radius: 0.75rem;
                                box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
                                border: 1px solid rgba(0, 0, 0, 0.05);
                                min-width: 280px;
                                width: 100%;
                                z-index: 9999;
                                margin-top: 0.25rem;
                                /* Prevent flicker */
                                will-change: transform, opacity;
                                pointer-events: auto;
                                /* Ensure it's above everything */
                                transform: translateZ(9999px);
                            }

                            .appointments-dropdown.active {
                                display: block;
                                animation: dropdownFadeIn 0.15s ease-out;
                            }

                            @@keyframes dropdownFadeIn {
                                from {
                                    opacity: 0;
                                    transform: translateY(-5px) translateZ(9999px);
                                }

                                to {
                                    opacity: 1;
                                    transform: translateY(0) translateZ(9999px);
                                }
                            }

                            [data-bs-theme="dark"] .appointments-dropdown {
                                background: #1e293b;
                                border-color: #334155;
                            }

                            .appointments-list {
                                max-height: 300px;
                                overflow-y: auto;
                                pointer-events: auto;
                            }

                            .appointment-item {
                                padding: 0.625rem 1rem;
                                transition: background 150ms ease;
                                border-bottom: 1px solid rgba(0, 0, 0, 0.05);
                                text-decoration: none;
                                display: block;
                                pointer-events: auto;
                            }

                            [data-bs-theme="dark"] .appointment-item {
                                border-bottom-color: rgba(255, 255, 255, 0.05);
                            }

                            .appointment-item:hover {
                                background: rgba(13, 110, 253, 0.05);
                            }

                            .status-indicator {
                                width: 8px;
                                height: 8px;
                                border-radius: 50%;
                                flex-shrink: 0;
                            }

                            .appointment-time-small {
                                font-size: 0.95rem;
                                font-weight: 600;
                                color: #0d6efd;
                                background: rgba(13, 110, 253, 0.1);
                                padding: 0.125rem 0.375rem;
                                border-radius: 0.375rem;
                            }

                            /* Add Button */
                            .add-appointment-btn {
                                position: absolute;
                                bottom: 0.5rem;
                                right: 0.5rem;
                                width: 28px;
                                height: 28px;
                                border-radius: 50%;
                                background: #0d6efd;
                                color: white;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                opacity: 0;
                                transition: all 150ms ease;
                                text-decoration: none;
                                box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
                            }

                            .calendar-day:hover .add-appointment-btn {
                                opacity: 1;
                            }

                            .add-appointment-btn:hover {
                                transform: scale(1.1);
                                color: white;
                                background: #0b5ed7;
                            }

                            /* Legend */
                            .legend {
                                padding-top: 0.5rem;
                                border-top: 1px solid rgba(13, 110, 253, 0.1);
                            }

                            .legend-item {
                                display: inline-flex;
                                align-items: center;
                                gap: 0.5rem;
                                font-size: 0.75rem;
                                color: #6c757d;
                            }

                            .legend-color {
                                width: 12px;
                                height: 12px;
                                border-radius: 3px;
                            }

                            .legend-color.today-indicator {
                                background: #0d6efd;
                                border: 1px solid white;
                                box-shadow: 0 0 0 1px #0d6efd;
                            }

                            /* Media Queries */
                            @@media (max-width: 992px) {
                                .calendar-grid {
                                    gap: 0.375rem;
                                }

                                .calendar-day {
                                    min-height: 100px;
                                    padding: 0.5rem;
                                }

                                .day-number {
                                    width: 28px;
                                    height: 28px;
                                    font-size: 0.8rem;
                                }
                            }

                            @@media (max-width: 768px) {
                                .calendar-card .card-body {
                                    padding: 1rem;
                                }

                                .calendar-grid {
                                    gap: 0.25rem;
                                }

                                .calendar-day {
                                    min-height: 80px;
                                    padding: 0.375rem;
                                    position: relative;
                                    overflow: visible;
                                }

                                .calendar-day-header {
                                    font-size: 0.7rem;
                                    padding: 0.5rem 0.25rem;
                                }

                                .day-number {
                                    width: 24px;
                                    height: 24px;
                                    font-size: 0.7rem;
                                }

                                .appointment-badge {
                                    font-size: 0.6rem;
                                    padding: 0.125rem 0.25rem;
                                }

                                .add-appointment-btn {
                                    width: 22px;
                                    height: 22px;
                                    font-size: 0.7rem;
                                }

                                .appointments-dropdown {
                                    min-width: 240px;
                                    left: -50%;
                                    right: auto;
                                }
                            }

                            /* Scrollbar */
                            .appointments-list::-webkit-scrollbar {
                                width: 4px;
                            }

                            .appointments-list::-webkit-scrollbar-track {
                                background: rgba(0, 0, 0, 0.05);
                                border-radius: 10px;
                            }

                            .appointments-list::-webkit-scrollbar-thumb {
                                background: #0d6efd;
                                border-radius: 10px;
                            }

                            .calendar-day.filter-active {
                                transform: translateY(-2px) translateZ(0);
                                z-index: 50;
                                color:
                                    @(currentFilter.GetCssColor())
                            }

                            .calendar-day.filter-active:hover {
                                transform: translateY(-4px) translateZ(0);
                                z-index: 100;
                            }

                            /* Dot indicator on filtered days */
                            .calendar-day.filter-active .day-number {
                                position: relative;
                            }

                            .calendar-day.filter-active .day-number::after {
                                content: '●';
                                position: absolute;
                                top: -8px;
                                right: -8px;
                                font-size: 10px;
                                color: inherit;
                            }

                            /* Force filter styles with !important to override other styles */
                            .calendar-day.filter-active {
                                transform: translateY(-2px) translateZ(0) !important;
                                z-index: 50 !important;
                            }

                            .calendar-day.filter-active:hover {
                                transform: translateY(-4px) translateZ(0) !important;
                                z-index: 100 !important;
                            }

                            /* Animated border for filtered days */
                            .calendar-day.filter-active {
                                animation: filterPulse 2s ease-in-out infinite;
                            }

                            @@keyframes filterPulse {

                                0%,
                                100% {
                                    box-shadow: 0 0 0 3px currentColor;
                                }

                                50% {
                                    box-shadow: 0 0 0 6px currentColor;
                                }
                            }
                        </style>
                    }

                    @section Scripts {
                        <script>
                            // Filter functionality
                            const statusFilter = document.getElementById('statusFilter');
                            const applyFilterBtn = document.getElementById('applyFilterBtn');
                            const clearFilterBtn = document.getElementById('clearFilterBtn');

                            function applyFilter() {
                                const status = statusFilter ? statusFilter.value : '';
                                const currentUrl = new URL(window.location.href);

                                // Preserve current month
                                const startDate = currentUrl.searchParams.get('startDate') || '@Model.CurrentMonth.ToString("yyyy-MM-dd")';

                                // Build new URL
                                const params = new URLSearchParams();
                                params.set('startDate', startDate);
                                if (status) {
                                    params.set('status', status);
                                }

                                window.location.href = `/Appointments/Calendar?${params.toString()}`;
                            }

                            function clearFilter() {
                                const currentUrl = new URL(window.location.href);
                                const startDate = currentUrl.searchParams.get('startDate') || '@Model.CurrentMonth.ToString("yyyy-MM-dd")';
                                window.location.href = `/Appointments/Calendar?startDate=${startDate}`;
                            }

                            if (applyFilterBtn) {
                                applyFilterBtn.addEventListener('click', applyFilter);
                            }

                            if (clearFilterBtn) {
                                clearFilterBtn.addEventListener('click', clearFilter);
                            }


                            document.addEventListener('DOMContentLoaded', function () {
                                const calendarWrapper = document.querySelector('.calendar-wrapper');
                                if (calendarWrapper) {
                                    calendarWrapper.style.opacity = '1';
                                    calendarWrapper.style.transform = 'translateY(0)';
                                }

                                // Initialize tooltips
                                var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
                                tooltipTriggerList.forEach(function (tooltipTriggerEl) {
                                    new bootstrap.Tooltip(tooltipTriggerEl);
                                });

                                // FIXED: Custom dropdown implementation - no Bootstrap interference
                                document.querySelectorAll('[data-dropdown-trigger="true"]').forEach(function (badge) {
                                    badge.addEventListener('click', function (e) {
                                        e.stopPropagation();
                                        e.preventDefault();

                                        var dropdown = this.nextElementSibling;
                                        if (!dropdown || !dropdown.classList.contains('appointments-dropdown')) return;

                                        // Close all other dropdowns first
                                        document.querySelectorAll('.appointments-dropdown.active').forEach(function (d) {
                                            if (d !== dropdown) {
                                                d.classList.remove('active');
                                                d.style.display = 'none';
                                            }
                                        });

                                        // Toggle current dropdown
                                        var isActive = dropdown.classList.contains('active');

                                        if (!isActive) {
                                            dropdown.style.display = 'block';
                                            // Force reflow to ensure transition works
                                            void dropdown.offsetWidth;
                                            dropdown.classList.add('active');
                                        } else {
                                            dropdown.classList.remove('active');
                                            setTimeout(function () {
                                                dropdown.style.display = 'none';
                                            }, 150);
                                        }
                                    });
                                });

                                // Close dropdown when clicking outside
                                document.addEventListener('click', function (e) {
                                    document.querySelectorAll('.appointments-dropdown.active').forEach(function (dropdown) {
                                        dropdown.classList.remove('active');
                                        setTimeout(function () {
                                            dropdown.style.display = 'none';
                                        }, 150);
                                    });
                                });

                                // IMPORTANT: Prevent dropdown from closing when clicking inside it
                                document.querySelectorAll('.appointments-dropdown').forEach(function (dropdown) {
                                    dropdown.addEventListener('click', function (e) {
                                        e.stopPropagation();
                                    });

                                    // Prevent dropdown from closing when scrolling inside it
                                    dropdown.addEventListener('wheel', function (e) {
                                        e.stopPropagation();
                                    });

                                    dropdown.addEventListener('scroll', function (e) {
                                        e.stopPropagation();
                                    });
                                });

                                // Navigation buttons - FIXED: Proper month calculation with padding
                                const prevBtn = document.getElementById('prevMonth');
                                const nextBtn = document.getElementById('nextMonth');
                                const todayBtn = document.getElementById('todayBtn');

                                let currentYear = @Model.CurrentMonth.Year;
                                let currentMonth = @Model.CurrentMonth.Month; // 1-based from Razor

                                function pad(num) {
                                    return num.toString().padStart(2, '0');
                                }

                                function updateCalendar(year, month) {
                                    const url = `/Appointments/Calendar?startDate=${year}-${pad(month)}-01`;
                                    window.location.href = url;
                                }

                                if (prevBtn) {
                                    prevBtn.addEventListener('click', function () {
                                        let newMonth = currentMonth - 1;
                                        let newYear = currentYear;
                                        if (newMonth < 1) {
                                            newMonth = 12;
                                            newYear--;
                                        }
                                        updateCalendar(newYear, newMonth);
                                    });
                                }

                                if (nextBtn) {
                                    nextBtn.addEventListener('click', function () {
                                        let newMonth = currentMonth + 1;
                                        let newYear = currentYear;
                                        if (newMonth > 12) {
                                            newMonth = 1;
                                            newYear++;
                                        }
                                        updateCalendar(newYear, newMonth);
                                    });
                                }

                                if (todayBtn) {
                                    todayBtn.addEventListener('click', function () {
                                        const today = new Date();
                                        const year = today.getFullYear();
                                        const month = pad(today.getMonth() + 1);
                                        const day = pad(today.getDate());
                                        window.location.href = `/Appointments/Calendar?startDate=${year}-${month}-${day}`;
                                    });
                                }
                            });
                        </script>
                    }